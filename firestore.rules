rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'email', 'isPaid']) &&
             data.uid is string && data.fullName is string && data.fullName.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.isPaid is bool &&
             data.uid == request.auth.uid;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['userId', 'razorpayPaymentId', 'amount']) &&
             data.userId == request.auth.uid &&
             data.amount == 500 &&
             data.razorpayPaymentId is string;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'gender', 'parentName', 'contactNumber', 'district', 'college', 'degree', 'department', 'subject', 'session', 'semester', 'universityRoll', 'internshipDomain', 'learningHours', 'progress', 'isPaid'])
      );
    }

    match /payments/{paymentId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(paymentId) && isValidPayment(incoming());
    }

    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(submissionId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
    }
  }
}
