rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
        (request.auth.token.get('email', '').lower() == "mrmunsi2014@gmail.com" ||
         request.auth.token.get('email', '').lower() == "admin@internmitra.com" ||
         (
           exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isActive == true &&
           get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['admin', 'super_admin']
         ));
    }
    function isTeacher() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isActive == true &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'teacher';
    }
    function teacherCourse() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.course;
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'email', 'isPaid']) &&
             data.uid is string && data.fullName is string && data.fullName.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.isPaid is bool &&
             data.uid == request.auth.uid;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['userId', 'razorpayPaymentId', 'amount']) &&
             data.userId == request.auth.uid &&
             (data.amount == 700 || data.amount == 1000) &&
             data.razorpayPaymentId is string;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'gender', 'parentName', 'contactNumber', 'district', 'college', 'degree', 'department', 'subject', 'session', 'semester', 'universityRoll', 'internshipDomain', 'learningHours', 'progress', 'isPaid', 'offerLetterNumber', 'totalHoursCompleted', 'lastVideoCompletedAt', 'certificateNumber'])
      );
    }

    match /payments/{paymentId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(paymentId) && isValidPayment(incoming());
    }

    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(submissionId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
    }

    match /admins/{adminId} {
      allow get: if isAdmin() || (isSignedIn() && adminId == request.auth.uid);
      allow list: if isAdmin();
      allow create, update: if isAdmin();
    }

    // Master data collections - public read, admin write
    match /districts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /colleges/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /universities/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /courses/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /degrees/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /counters/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /dailyVideos/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() || (isTeacher() && incoming().course == teacherCourse());
      allow delete: if isAdmin() || (isTeacher() && existing().course == teacherCourse());
    }

    match /attendance/{attendanceId} {
      allow get, list: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid) ||
        (isTeacher() && resource.data.course == teacherCourse());
      allow create: if isSignedIn() &&
        incoming().userId == request.auth.uid &&
        incoming().course is string &&
        incoming().day is number &&
        incoming().videoId is string;
    }

    match /courseCompletion/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() || (isTeacher() && incoming().course == teacherCourse());
    }

    match /userVideoProgress/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}
